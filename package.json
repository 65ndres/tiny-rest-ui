    "@eslint/js": "^9.37.0",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.37.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react": "^7.37.5",
