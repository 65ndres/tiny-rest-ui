{
  "name": "tiny-rest",
  "main": "expo-router/entry",
  "version": "2.1.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:dev": "expo start --dev-client",
    "start:prod": "expo start --no-dev --minify",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:prod": "expo run:android --variant release",
    "ios": "expo run:ios",
    "ios:simulator": "expo run:ios --device \"iPhone 16\"",
    "ios:prod": "expo run:ios --configuration Release",
    "web": "expo start --web",
    "prebuild": "npx expo prebuild",
    "lint": "expo lint",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "prewidget": "EXPO_NO_GIT_STATUS=1 npx expo prebuild --template ./node_modules/@bacons/apple-targets/prebuild-blank.tgz --clean",
    "sync:ios-app-groups": "node scripts/sync-ios-app-groups.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@bacons/apple-targets": "4.0.6",
    "@expo/html-elements": "^0.12.5",
    "@expo/ngrok": "^4.1.3",
