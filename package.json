    "@react-navigation/native-stack": "^7.3.10",
    "@react-navigation/stack": "^7.4.8",
    "@rneui/base": "^0.0.0-edge.2",
    "@rneui/themed": "^0.0.0-edge.2",
    "axios": "^1.12.2",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
