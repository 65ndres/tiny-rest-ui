# Copy this file to .env and fill in values. Never commit .env (it's in .gitignore).
#
# Security: Variables prefixed with EXPO_PUBLIC_ are embedded in the app bundle
# and can be read by users. Use them only for keys that are meant to be public
# (e.g. RevenueCat public API key). For truly secret keys, use a backend server.
#
# RevenueCat: https://app.revenuecat.com → Project Settings → API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_fRNVsmAodOjAPdRxiggZsgREVzt
#
# Add other API keys as needed (EXPO_PUBLIC_ = available in the app at runtime):
# EXPO_PUBLIC_SOME_API_KEY=
